{
  "manifest_version": 3,
  "name": "Interview Assistant",
  "version": "1.0.0",
  "description": "在 Markdown 笔记中隐藏答案，点击显示 — 面试复习利器",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "file:///*.md",
    "file:///*.markdown",
    "https://github.com/*",
    "https://gitlab.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "file:///*.md",
        "file:///*.markdown",
        "https://github.com/*/*/blob/*",
        "https://gitlab.com/*/*/blob/*",
        "https://raw.githubusercontent.com/*/*.md",
        "https://raw.githubusercontent.com/*/*.markdown"
      ],
      "js": ["parser.js", "content-script.js"],
      "css": ["content-style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
